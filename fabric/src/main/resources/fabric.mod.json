{
  "schemaVersion": 1,
  "id": "phats_progression",
  "version": "${version}",
  "name": "Phat's Progression Framework",
  "description": "A modpack-configurable mining tier progression system that extends the vanilla tier system past netherite. Define which blocks require which tools entirely through config.",
  "authors": [
    "Phatdog731"
  ],
  "contact": {
    "sources": "https://github.com/Phatdog731/phats_progression"
  },
  "license": "MIT",
  "icon": "assets/phats_progression/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.phatdog.phatsprogression.fabric.PhatsProgressionFabric"
    ],
    "client": [
      "com.phatdog.phatsprogression.fabric.client.PhatsProgressionFabricClient"
    ]
  },
  "mixins": [
    "phats_progression.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "architectury": ">=19.0.1",
    "fabric-api": "*"
  }
}